{
  "expo": {
    "name": "QR Code Creator",
    "slug": "qr-code-creator-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "האפליקציה זקוקה לגישה למצלמה כדי לסרוק קודי QR",
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "האפליקציה צריכה גישה לתמונות כדי לבחור לוגו ל-QR."
        }
      ]
    ],
    "android": {
      "package": "com.qrcodecreator.mobile"
    }
  }
}
